# Airtable: create a Personal Access Token at airtable.com/create/tokens
AIRTABLE_PAT=
# Base ID from the API docs URL of your base (starts with app...)
AIRTABLE_BASE_ID=
# Table name exactly as in Airtable (e.g. Resorts)
AIRTABLE_TABLE_NAME=

# Optional: comma-separated fallbacks for column names (defaults shown in code)
# AIRTABLE_FIELD_NAME=Name,Resort,Property,Title
# AIRTABLE_FIELD_LOCATION=Location,City,Destination,Address,Region
# AIRTABLE_FIELD_LAT=Lat,Latitude
# AIRTABLE_FIELD_LNG=Lng,Longitude,Lon
# AIRTABLE_FIELD_AIRPORT=Airport,IATA,Nearest Airport

# Optional: Amadeus Self-Service (test.api.amadeus.com by default)
# AMADEUS_CLIENT_ID=
# AMADEUS_CLIENT_SECRET=
# Uncomment for production Amadeus hostname:
# AMADEUS_HOSTNAME=api.amadeus.com
